  year      = {2011},
  volume    = {19},
  number    = {4},
  pages     = {3163--3174},
  doi       = {10.1364/OE.19.003163},
  abstract  = {We characterize an approach to make ultra-low-loss waveguides using stable and reproducible stoichiometric Si3N4 deposited with low-pressure chemical vapor deposition. Using a high-aspect-ratio core geometry, record low losses of 8-9 dB/m for a 0.5 mm bend radius down to 3 dB/m for a 2 mm bend radius are measured with ring resonator and optical frequency domain reflectometry techniques.},
