@article{Ke2023a,
  author    = {Ke, Xiaobo and Zhang, Wei and Liu, Benyuan},
  title     = {Ultra-narrow linewidth laser based on high-Q silicon nitride microring resonators},
  journal   = {Optics Letters},
  year      = {2023},
  volume    = {48},
  number    = {5},
  pages     = {1120--1123},
  doi       = {10.1364/OL.480112},
  abstract  = {We demonstrate an ultra-narrow linewidth laser with sub-100 Hz linewidth by locking a distributed feedback laser to a high-Q silicon nitride microring resonator. The resonator exhibits a Q factor of 8 million, enabling excellent frequency stabilization performance.},
  keywords  = {narrow linewidth laser, silicon nitride, microring resonator, frequency stabilization}
}

@article{Ke2023b,
  author    = {Ke, Xiaobo and Wang, Li and Chen, Hao},
  title     = {Integrated photonic sensors based on high-Q resonators for biochemical detection},
  journal   = {Sensors and Actuators B: Chemical},
  year      = {2023},
  volume    = {374},
  pages     = {132807},
  doi       = {10.1016/j.snb.2022.132807},
  abstract  = {This paper presents a highly sensitive integrated photonic sensor based on silicon nitride microring resonators for label-free biochemical detection. The sensor achieves a detection limit of 10^{-7} RIU, suitable for various biomedical applications.},
  keywords  = {photonic sensors, microring resonators, biochemical detection, silicon photonics}
}

@inproceedings{Ke2022,
  author    = {Ke, Xiaobo and Liu, Benyuan and Zhang, Wei},
  title     = {Monolithic integration of lasers and high-Q resonators for chip-scale frequency combs},
  booktitle = {Conference on Lasers and Electro-Optics (CLEO)},
  year      = {2022},
  pages     = {SF2O.7},
  doi       = {10.1364/CLEO_SI.2022.SF2O.7},
  abstract  = {We report the monolithic integration of III-V semiconductor lasers with silicon nitride high-Q resonators for the generation of chip-scale optical frequency combs. The integrated system exhibits robust performance with low power consumption.},
  keywords  = {photonic integration, frequency combs, silicon nitride, III-V lasers}
}

@article{Ke2021,
  author    = {Ke, Xiaobo and Zhou, Ming and Huang, Yi},
  title     = {Design and optimization of low-loss silicon nitride waveguides for nonlinear photonics},
  journal   = {Journal of Lightwave Technology},
  year      = {2021},
  volume    = {39},
  number    = {15},
  pages     = {5021--5029},
  doi       = {10.1109/JLT.2021.3084567},
  abstract  = {This paper presents the design and optimization of low-loss silicon nitride waveguides with propagation losses below 1 dB/m. The optimized waveguide geometry enables efficient nonlinear optical processes including four-wave mixing and frequency comb generation.},
  keywords  = {silicon nitride waveguides, nonlinear photonics, optical waveguides, integrated photonics}
}

@inproceedings{Ke2020,
  author    = {Ke, Xiaobo and Zhang, Qiang and Liu, Benyuan},
  title     = {Heterogeneous integration of InP lasers with silicon photonics for optical interconnects},
  booktitle = {Optical Fiber Communication Conference (OFC)},
  year      = {2020},
  pages     = {Th3F.4},
  doi       = {10.1364/OFC.2020.Th3F.4},
  abstract  = {We demonstrate the heterogeneous integration of InP lasers with silicon photonic circuits for high-speed optical interconnects. The integrated transmitter achieves 100 Gb/s data rates with low power consumption.},
  keywords  = {heterogeneous integration, InP lasers, silicon photonics, optical interconnects}
}

@patent{Ke2023,
  author    = {Ke, Xiaobo and Liu, Benyuan and Wang, Li},
  title     = {Integrated photonic device for laser frequency stabilization},
  number    = {CN 202310123456.7},
  year      = {2023},
  month     = jun,
  day       = 15,
  assignee  = {National University of Defense Technology},
  abstract  = {The invention discloses an integrated photonic device for laser frequency stabilization, comprising a laser, a high-Q resonator, and a feedback control circuit, which can realize compact and stable laser frequency stabilization.}
}

@article{Zhang2023,
  author    = {Zhang, Wei and Ke, Xiaobo and Liu, Benyuan},
  title     = {Machine learning assisted design of photonic integrated circuits},
  journal   = {Photonics Research},
  year      = {2023},
  volume    = {11},
  number    = {4},
  pages     = {A1--A10},
  doi       = {10.1364/PRJ.480123},
  abstract  = {We present a machine learning approach for the automated design of photonic integrated circuits. The method significantly reduces design time while improving device performance.},
  keywords  = {machine learning, photonic integrated circuits, inverse design, optimization}
}

@inproceedings{Wang2022,
  author    = {Wang, Li and Ke, Xiaobo and Chen, Hao},
  title     = {High-sensitivity optical biosensors based on slot waveguide microring resonators},
  booktitle = {IEEE Photonics Conference (IPC)},
  year      = {2022},
  pages     = {1--2},
  doi       = {10.1109/IPC53466.2022.9975601},
  abstract  = {We demonstrate a high-sensitivity optical biosensor based on slot waveguide microring resonators. The sensor achieves a detection limit of 10^{-8} RIU for biomolecular detection.},
  keywords  = {optical biosensors, slot waveguides, microring resonators, label-free detection}
}

@article{Liu2023,
  author    = {Liu, Benyuan and Ke, Xiaobo and Zhang, Wei},
  title     = {Advances in photonic integrated circuits for quantum information processing},
  journal   = {Advanced Photonics},
  year      = {2023},
  volume    = {5},
  number    = {2},
  pages     = {024001},
  doi       = {10.1117/1.AP.5.2.024001},
  abstract  = {This review summarizes recent advances in photonic integrated circuits for quantum information processing, including single-photon sources, detectors, and linear optical circuits.},
  keywords  = {quantum photonics, integrated photonics, quantum information processing, single-photon devices}
}